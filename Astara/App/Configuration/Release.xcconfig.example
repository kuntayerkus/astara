// Release Configuration — Copy to Release.xcconfig and fill in real values
// NEVER commit the real .xcconfig file (it's in .gitignore)

API_BASE_URL = https:$()/$()/astara.app/api
VPS_URL = https:$()/$()/swiss.grio.works
VPS_API_KEY = YOUR_PRODUCTION_VPS_API_KEY_HERE
GEONAMES_USERNAME = YOUR_GEONAMES_USERNAME_HERE
GEMINI_API_KEY = REPLACE_WITH_REAL_GEMINI_KEY
SUPABASE_URL = https:$()/$()/REPLACE_WITH_REAL_SUPABASE_URL
SUPABASE_ANON_KEY = REPLACE_WITH_REAL_SUPABASE_ANON_KEY
